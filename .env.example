# ============================================
# KOS MANAGEMENT SYSTEM — Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- Database ---
DB_USER=kos_admin
DB_PASSWORD=changeme_in_production
DB_NAME=kos_management

# --- Backend ---
JWT_SECRET=generate_a_random_64_char_string_here
BASE_URL=https://kos.j99t.tech

# --- Midtrans Payment Gateway ---
# Daftar di https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
MIDTRANS_IS_PRODUCTION=false

# --- Hermes Agent ---
HERMES_API_KEY=generate_random_api_key_for_hermes

# --- LLM Provider (untuk Hermes) ---
# Pakai provider apapun yang OpenAI-compatible.
# Cukup set BASE_URL, API_KEY, dan MODEL.
#
# Contoh konfigurasi:
#
# OpenRouter:
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_API_KEY=sk-or-xxxxxxx
#   LLM_MODEL=google/gemini-flash-1.5
#
# OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_API_KEY=sk-xxxxxxx
#   LLM_MODEL=gpt-4o-mini
#
# Anthropic (via OpenAI proxy):
#   LLM_BASE_URL=https://api.anthropic.com/v1
#   LLM_API_KEY=sk-ant-xxxxxxx
#   LLM_MODEL=claude-sonnet-4-20250514
#
# Google Gemini (OpenAI-compatible):
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   LLM_API_KEY=AIzaxxxxxxx
#   LLM_MODEL=gemini-2.0-flash
#
# LM Studio / Ollama / vLLM / LocalAI (lokal):
#   LLM_BASE_URL=http://host.docker.internal:1234/v1
#   LLM_API_KEY=not-needed
#   LLM_MODEL=hermes-3-llama-3.1-8b
#
# Together AI:
#   LLM_BASE_URL=https://api.together.xyz/v1
#   LLM_API_KEY=xxxxxxx
#   LLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
#
# Groq:
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_API_KEY=gsk_xxxxxxx
#   LLM_MODEL=llama-3.3-70b-versatile

LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-xxxxxxx
LLM_MODEL=google/gemini-flash-1.5

# --- Cloudflare Tunnel ---
# Buat tunnel di https://one.dash.cloudflare.com → Networks → Tunnels
# Klik tunnel → konfigurasi → copy token
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoixxxxxx

# --- Seed (opsional) ---
# Password admin awal yang dibuat saat seeding database.
# Ganti dari default sebelum produksi.
SEED_ADMIN_PASSWORD=admin123

# --- Hermes Dashboard (login bot dashboard) ---
# Bind dashboard ke 0.0.0.0 mengaktifkan auth gate Hermes; isi kredensial ini.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=ganti_password_kuat_disini
# Secret tetap supaya sesi login awet setelah restart: openssl rand -base64 32
DASHBOARD_SECRET=
